# ─────────────────────────────────────────────────────────────────────────────
# GA3.ai — environment configuration
#
# Copy this file to `.env.local` and fill in the values:
#     cp .env.example .env.local
#
# Never commit `.env.local` — it is gitignored. Only this example is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth (required) ──────────────────────────────────────────────────
# Create an OAuth 2.0 Client (type: Web application) at:
#   https://console.cloud.google.com/auth/clients
# Add an Authorized redirect URI that matches GOOGLE_REDIRECT_URI below.
# Enable the "Google Analytics Data API" + "Google Analytics Admin API" for the project.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match an Authorized redirect URI on the OAuth client.
# Local dev:  http://localhost:3000/api/auth/callback
# Production: https://your-domain.com/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── AI + data providers (required) ───────────────────────────────────────────
# Anthropic (Claude) — powers chat, briefings, narrative.  https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Voyage AI — text embeddings for context search.          https://www.voyageai.com
VOYAGE_API_KEY=pa-...
# ScrapingDog — fetches public web pages for business context.  https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=your-scrapingdog-key

# ── Session (required) ───────────────────────────────────────────────────────
# Secret used to encrypt the iron-session cookie. Use a long random string:
#   openssl rand -base64 32
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# ── Admin dashboard (optional) ───────────────────────────────────────────────
# Your Google account email — grants access to the usage/cost dashboard at /admin.
OWNER_EMAIL=
# Extra admin emails, comma-separated (optional).
ADMIN_EMAILS=

# ── Storage (optional) ───────────────────────────────────────────────────────
# SQLite database file path. Defaults to a local file under the project.
# In production, point this at a mounted persistent volume, e.g. /data/ga3.db
DB_PATH=

# ── Google Ads connect (optional — only if you enable the Ads feature) ────────
# Requires the additional, sensitive `.../auth/adwords` OAuth scope.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── Display / cost tuning (optional) ─────────────────────────────────────────
# USD→INR rate used for the admin cost dashboard display (default 83).
NEXT_PUBLIC_USD_TO_INR=83
# Provider unit costs for the admin cost estimates (sensible defaults if unset).
SCRAPINGDOG_USD_PER_CREDIT=
VOYAGE_USD_PER_MTOK=
